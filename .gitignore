# ===== Khata data — must NEVER enter git =====
# The encrypted database, keyfile, and any backups live outside the repo,
# but guard against accidental commits regardless.
../khata-data/
khata-data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.keys
*.sealed
backups/
khata.config.json

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
*.egg-info/
.eggs/

# ===== Tooling / caches =====
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ===== Packaging / build artifacts =====
build/
dist/
*.spec.bak
*.exe

# ===== OS / editor =====
.DS_Store
.idea/
.vscode/
